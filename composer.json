{
    "name": "because/bonsai-theme",
    "description": "High-density, compact UI theme for Filament v5",
    "keywords": ["filament", "laravel", "theme", "japanese", "high-density", "compact", "bonsai"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Because\\BonsaiTheme\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Because\\BonsaiTheme\\BonsaiThemeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
